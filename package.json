{
  "name": "psytool",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "cd apps/web && npx vite",
    "mobile": "cd apps/mobile && npx expo start",
    "mobile:dev": "cd apps/mobile && npx expo start --dev-client",
    "test:mobile": "cd apps/mobile && npx jest --no-coverage",
    "test:web": "cd apps/web && npx vitest run",
    "test:shared": "cd packages/shared && npx vitest run",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "overrides": {
    "react": "19.1.0"
  },
  "version": "1.0.0"
}
