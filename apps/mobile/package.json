{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~54.0.33",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.0.6",
    "lucide-react-native": "^1.12.0",
    "react": "^19.1.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.81.5",
    "react-native-get-random-values": "^2.0.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.12"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-markdown-display)"
    ],
    "moduleNameMapper": {
      "^react$": "<rootDir>/node_modules/react",
      "^react/jsx-runtime$": "<rootDir>/node_modules/react/jsx-runtime",
      "^react/jsx-dev-runtime$": "<rootDir>/node_modules/react/jsx-dev-runtime",
      "^expo-sqlite$": "<rootDir>/src/__mocks__/expo-sqlite.ts",
      "^expo-notifications$": "<rootDir>/src/__mocks__/expo-notifications.ts",
      "^expo-image-picker$": "<rootDir>/src/__mocks__/expo-image-picker.ts",
      "^react-native-markdown-display$": "<rootDir>/src/__mocks__/react-native-markdown-display.tsx",
      "^react-i18next$": "<rootDir>/src/__mocks__/react-i18next.ts",
      "^expo-localization$": "<rootDir>/src/__mocks__/expo-localization.ts",
      "^react/(.*)$": "<rootDir>/node_modules/react/$1"
    }
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
