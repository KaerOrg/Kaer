{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@ui/*": ["./src/components/ui/*"],
      "@theme": ["./src/theme"],
      "@services/*": ["./src/services/*"]
    }
  }
}
