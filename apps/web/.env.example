# Variables d'environnement — web praticien (Vite)
#
# Usage : copier ce fichier en `.env.local` et y mettre les vraies valeurs.
#   cp .env.example .env.local
# `.env.local` est gitignoré — ne JAMAIS committer de vraies valeurs.
#
# ⚠️ Les variables préfixées VITE_ sont embarquées dans le bundle navigateur :
# elles sont donc PUBLIQUES. N'y mettre que des valeurs publiques.
# La clé anon Supabase est conçue pour être exposée côté client.
# Tout secret serveur (ex. RESEND_API_KEY) va dans les secrets Supabase, jamais ici.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
